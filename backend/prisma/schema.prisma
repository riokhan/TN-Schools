generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URI")
}

// ─── Enums ────────────────────────────────────────────────────

enum Role {
  STUDENT
  PARENT
  TEACHER
  HEADMASTER
  BEO
  DEO
  COMMISSIONER
  MINISTER
  SUPERADMIN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum ScholarshipStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
}

// ─── Core Entities ────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  emisId       String?  @unique // EMIS Student ID
  aadhaarHash  String?  @unique // Hashed Aadhaar (never store raw)
  mobile       String?  @unique
  name         String
  email        String?  @unique
  passwordHash String?
  role         Role     @default(STUDENT)
  isActive     Boolean  @default(true)
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  student      Student?
  teacher      Teacher?
  notifications Notification[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model School {
  id                  String       @id @default(uuid())
  dise                String       @unique // DISE code
  name                String
  address             String?
  headmasterName      String?      @default("N/A")
  district            String
  block               String
  pincode             String?
  schoolType          String       @default("Government") // Government, Aided, etc.
  mediumOfInstruction String       @default("Tamil")
  classes             String[] // e.g. ["6","7","8","9","10","11","12"]
  users               User[]
  students            Student[]
  teachers            Teacher[]
  attendance          Attendance[]
  timetables          Timetable[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model Student {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id])
  schoolId     String
  school       School        @relation(fields: [schoolId], references: [id])
  class        String // "6" to "12"
  section      String // "A", "B", "C" etc.
  rollNumber   String?
  dob          DateTime?
  gender       String?
  religion     String?
  caste        String? // For scholarship eligibility
  parentName   String?
  parentMobile String?
  attendance   Attendance[]
  marks        Mark[]
  scholarships Scholarship[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  clubMembers  ClubMember[]
  portfolio    Portfolio?
  sportsProfile SportsProfile?
}

model Teacher {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id])
  employeeId    String?   @unique
  subjects      String[] // ["Mathematics", "Science"]
  qualification String?
  joiningDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── ClassRoom Entity ──────────────────────────────────────────

model ClassRoom {
  id           String   @id @default(uuid())
  schoolId     String
  teacherId    String?  // UUID of teacher user
  className    String   // e.g. "10"
  section      String   // e.g. "A"
  subject      String   // e.g. "Mathematics"
  academicYear String   @default("2024-25")
  roomNumber   String?  // e.g. "Room 12"
  schedule     String?  // e.g. "Mon/Wed/Fri 9AM"
  totalStudents Int     @default(0)
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
  @@index([teacherId])
}

// ─── Academic Entities ─────────────────────────────────────────

model Mark {
  id           String   @id @default(uuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  subject      String
  examType     String // "Unit1", "Midterm", "Annual", "Mock"
  maxMarks     Int      @default(100)
  scored       Int
  grade        String?
  academicYear String   @default("2024-25")
  createdAt    DateTime @default(now())

  @@index([studentId, subject, examType])
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id])
  schoolId  String
  school    School           @relation(fields: [schoolId], references: [id])
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  method    String? // "QR", "RFID", "Biometric", "Manual"
  createdAt DateTime         @default(now())

  @@unique([studentId, date])
  @@index([studentId, date])
  @@index([schoolId, date])
}

model Timetable {
  id        String   @id @default(uuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  class     String
  section   String
  dayOfWeek Int // 0=Mon ... 4=Fri
  period    Int // 1-8
  subject   String
  teacherId String?
  startTime String // "09:00"
  endTime   String // "09:45"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, class, section, dayOfWeek, period])
}

// ─── Welfare & Governance ─────────────────────────────────────

model Scholarship {
  id            String            @id @default(uuid())
  studentId     String
  student       Student           @relation(fields: [studentId], references: [id])
  scheme        String // "BC/MBC", "SC/ST", "Minority"
  amount        Float
  status        ScholarshipStatus @default(PENDING)
  appliedDate   DateTime          @default(now())
  approvedDate  DateTime?
  disbursedDate DateTime?
  remarks       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model MidDayMeal {
  id             String   @id @default(uuid())
  schoolId       String
  date           DateTime
  studentsServed Int
  menuItems      String[]
  stockUsedKg    Float?
  wastePercent   Float?
  supplierId     String?
  createdAt      DateTime @default(now())

  @@unique([schoolId, date])
  @@index([schoolId, date])
}

model SchoolAsset {
  id           String    @id @default(uuid())
  schoolId     String
  category     String // "SmartClassroom", "Computer", "Furniture", "Sports"
  name         String
  quantity     Int
  condition    String    @default("Good") // "Good", "Needs Repair", "Condemned"
  purchaseDate DateTime?
  value        Float?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())
}

// ─── Headmaster Portal ─────────────────────────────────────────

model WatchlistStudent {
  id         String   @id @default(uuid())
  name       String
  rollNumber String
  class      String
  phone      String   @default("N/A")
  parentName String   @default("N/A")
  district   String   @default("N/A")
  state      String   @default("N/A")
  city       String   @default("N/A")
  pincode    String   @default("N/A")
  risk       String   @default("Medium") // "High" | "Medium"
  schoolId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([schoolId])
  @@index([risk])
}

model HeadmasterStaff {
  id          String   @id @default(uuid())
  name        String
  emisId      String   @unique
  subject     String   @default("General")
  phone       String   @default("N/A")
  email       String?
  attendance  Float    @default(100)
  performance String   @default("Good") // "Excellent" | "Good" | "Average"
  leaveUsed   Int      @default(0)
  password    String   @default("123456")
  schoolId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

model HeadmasterTempStaff {
  id        String   @id @default(uuid())
  name      String
  role      String
  agency    String   @default("Direct Contract")
  joined    String   @default("")
  phone     String   @default("N/A")
  email     String   @default("N/A")
  duration  String   @default("12 Months")
  salary    String   @default("N/A")
  status    String   @default("Active")
  password  String   @default("123456")
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

model HeadmasterParent {
  id           String   @id @default(uuid())
  name         String
  role         String
  phone        String
  email        String?
  studentName  String   @default("N/A")
  studentClass String   @default("N/A")
  term         String
  password     String   @default("123456")
  schoolId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
}

model HeadmasterAlumni {
  id           String   @id @default(uuid())
  name         String
  batch        String
  contribution String
  role         String
  phone        String
  email        String
  location     String
  value        String   @default("N/A")
  schoolId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
}

model StudyMaterial {
  id           String   @id @default(uuid())
  title        String
  category     String // "Notes", "Worksheet", "Video Reference", "Exam Prep"
  classSection String // "Class 10A", etc.
  format       String // "PDF", "Link", etc.
  size         String // "2.4 MB"
  date         String   @default("Today")
  schoolId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
}

model Announcement {
  id           String   @id @default(uuid())
  title        String
  body         String
  target       String // "Class 10A Parents", etc.
  date         String   @default("Today")
  sender       String // "You (Science Specialist)", etc.
  pinned       Boolean  @default(false)
  readReceipts String?  @default("0/40 read")
  schoolId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
}

model Homework {
  id          String               @id @default(uuid())
  title       String
  className   String
  dueDate     String
  status      String               @default("active") // "active", "draft", "completed"
  description String
  schoolId    String?
  submissions HomeworkSubmission[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([schoolId])
}

model HomeworkSubmission {
  id         String   @id @default(uuid())
  homeworkId String
  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  rollNo     String
  name       String
  status     String // "submitted", "pending"
  score      String?  @default("—")
  date       String?  @default("—")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([homeworkId])
}

model EvaluationSubmission {
  id          String   @id @default(uuid())
  studentName String
  rollNo      String
  status      String   @default("pending") // "pending", "graded"
  score       Float?
  totalMarks  Int      @default(10)
  submittedAt String
  ocrContent  Json // Array of questions, student answers, AI scores, rationale
  schoolId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

model LabEquipment {
  id           String   @id @default(uuid())
  name         String
  classSection String
  status       String // "active", "scheduled", "completed"
  date         String
  safetyCheck  Boolean  @default(true)
  schoolId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
}

model LeaveRequest {
  id        String   @id @default(uuid())
  type      String
  duration    String
  reason      String
  studentName String   @default("Unknown")
  status      String   @default("Pending") // "Approved", "Pending", "Rejected"
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

model LessonPlan {
  id        String   @id @default(uuid())
  syllabus  String
  grade     String
  subject   String
  topic     String
  duration  String
  planData  Json // Stores outline, bilingual terms, assessments, exit tickets
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

model Question {
  id         String   @id @default(uuid())
  grade      String
  subject    String
  topic      String
  difficulty String // "easy", "medium", "hard"
  type       String // "mcq", "short", "long"
  text       String
  options    String[] // For MCQs
  answer     String
  marks      Int
  schoolId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([schoolId])
}

model StudentBadge {
  id           String   @id @default(uuid())
  studentId    String
  studentName  String
  classSection String
  badge        String
  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([studentId])
}

// ─── Extracurricular Activities (Student Portal) ───────────────

model Club {
  id         String   @id @default(uuid())
  schoolId   String?
  name       String
  category   String // "Environment", "Arts", "Science", "Academics", "Literature"
  icon       String // e.g. "🌱", "🎭"
  themeColor String // e.g. "text-emerald-600 dark:text-emerald-400"
  themeBg    String // e.g. "bg-emerald-500/10 border-emerald-500/20"
  themeTagBg String // e.g. "bg-emerald-500/20"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members ClubMember[]
  events  ClubEvent[]

  @@index([schoolId])
}

model ClubMember {
  id        String   @id @default(uuid())
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  role      String   @default("Member") // "Member", "President", etc.
  joinedAt  DateTime @default(now())

  @@unique([clubId, studentId])
  @@index([clubId])
  @@index([studentId])
}

model ClubEvent {
  id         String   @id @default(uuid())
  clubId     String?
  club       Club?    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  schoolId   String?
  title      String
  eventDate  DateTime
  type       String // "School-wide", "Competition", "Showcase", etc.
  icon       String
  themeColor String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([clubId])
  @@index([schoolId])
}

// ─── Student Portfolio ─────────────────────────────────────────

model Portfolio {
  id           String   @id @default(uuid())
  studentId    String   @unique
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  bio          String?
  stream       String?  @default("General")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  skills       PortfolioSkill[]
  projects     PortfolioProject[]
  achievements PortfolioAchievement[]
}

model PortfolioSkill {
  id          String   @id @default(uuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  name        String
  level       Int      // e.g., 90
  color       String   // e.g., "from-rose-500 to-pink-500"
  createdAt   DateTime @default(now())

  @@index([portfolioId])
}

model PortfolioProject {
  id          String   @id @default(uuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  title       String
  category    String
  date        String
  image       String   // emoji like "🏙️"
  tags        String[] // ["IoT", "Physics"]
  description String
  createdAt   DateTime @default(now())

  @@index([portfolioId])
}

model PortfolioAchievement {
  id          String   @id @default(uuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  title       String
  year        String
  icon        String   // emoji like "🏆"
  color       String
  bg          String
  createdAt   DateTime @default(now())

  @@index([portfolioId])
}

// ─── Student Sports ────────────────────────────────────────────

model SportsProfile {
  id           String   @id @default(uuid())
  studentId    String   @unique
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teams        SportsTeam[]
  stats        SportsFitnessStat[]
  events       SportsEvent[]
  logs         SportsHealthLog[]
}

model SportsTeam {
  id              String   @id @default(uuid())
  sportsProfileId String
  sportsProfile   SportsProfile @relation(fields: [sportsProfileId], references: [id], onDelete: Cascade)
  name            String
  role            String
  icon            String
  color           String
  match           String
  date            String
  createdAt       DateTime @default(now())

  @@index([sportsProfileId])
}

model SportsFitnessStat {
  id              String   @id @default(uuid())
  sportsProfileId String
  sportsProfile   SportsProfile @relation(fields: [sportsProfileId], references: [id], onDelete: Cascade)
  label           String
  value           String
  score           Int
  icon            String
  color           String
  createdAt       DateTime @default(now())

  @@index([sportsProfileId])
}

model SportsEvent {
  id              String   @id @default(uuid())
  sportsProfileId String
  sportsProfile   SportsProfile @relation(fields: [sportsProfileId], references: [id], onDelete: Cascade)
  title           String
  date            String
  type            String
  icon            String
  createdAt       DateTime @default(now())

  @@index([sportsProfileId])
}

model SportsHealthLog {
  id              String   @id @default(uuid())
  sportsProfileId String
  sportsProfile   SportsProfile @relation(fields: [sportsProfileId], references: [id], onDelete: Cascade)
  date            String
  activity        String
  duration        String
  calories        Int
  intensity       String   // "High", "Low", "Maximum"
  createdAt       DateTime @default(now())

  @@index([sportsProfileId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
